---
import { Image } from "astro:assets"
import dashboardImg from "../assets/packstack-pack-dashboard.png"
import inventoryImg from "../assets/gear-inventory-screenshot.png"
import weightImg from "../assets/pack-weight-breakdown.png"
import BaseLayout from "../layouts/BaseLayout.astro"
import PageHeader from "../components/PageHeader.astro"
import PageFooter from "../components/PageFooter.astro"

export const prerender = true
---

<BaseLayout title="Packstack | The Backpacking Packing App">
  <div class="bg-background">
    <PageHeader maxWidth="6xl" />

    <!-- Hero -->
    <section class="pt-16 pb-8 md:pt-24 md:pb-16 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight tracking-tight">
          Plan Lighter. Pack Smarter.<br class="hidden sm:block" />
          Hike Further.
        </h1>
        <p class="mt-6 text-lg md:text-xl max-w-lg mx-auto leading-relaxed">
          The packing list and gear management app built for backpackers
          and ultralight hikers.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="https://app.packstack.io/auth/register"
            class="bg-primary hover:bg-primary-dark text-white rounded-md py-3 px-8 font-bold text-lg transition-colors no-underline w-full sm:w-auto text-center"
          >
            Get Started Free
          </a>
          <a
            href="#features"
            class="border border-border hover:border-softwhite text-softwhite hover:text-white rounded-md py-3 px-8 font-semibold text-lg transition-colors no-underline w-full sm:w-auto text-center"
          >
            See How It Works
          </a>
        </div>
      </div>

      <!-- Dashboard screenshot in browser frame -->
      <div class="max-w-6xl mx-auto mt-12 md:mt-16">
        <div class="rounded-xl border border-border overflow-hidden shadow-2xl shadow-primary-glow">
          <div class="bg-surface flex items-center gap-2 px-4 py-2.5">
            <span class="w-3 h-3 rounded-full bg-accent-red/60"></span>
            <span class="w-3 h-3 rounded-full bg-accent-orange/60"></span>
            <span class="w-3 h-3 rounded-full bg-accent-green/60"></span>
            <span class="ml-4 text-label text-xs font-mono">app.packstack.io</span>
          </div>
          <Image
            src={dashboardImg}
            alt="Packstack dashboard showing a packing list with categorized gear, weights, and trip details"
            class="w-full block"
          />
        </div>
      </div>
    </section>

    <!-- Features -->
    <div id="features" class="scroll-mt-20">

      <!-- Feature: Gear Inventory -->
      <section class="py-16 md:py-24 px-4">
        <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center gap-8 md:gap-12">
          <div class="md:w-5/12">
            <h2 class="text-xs uppercase tracking-widest mb-3 font-semibold">Gear Inventory</h2>
            <h3 class="text-2xl md:text-3xl leading-snug mb-4">Every gram accounted for</h3>
            <p class="mb-5">
              Build a comprehensive gear inventory with detailed specs for every
              item — weight, brand, product, price, and category. Your inventory
              is always at your fingertips when building packing lists.
            </p>
            <ul class="space-y-2.5 text-softwhite text-sm">
              <li class="flex items-start gap-2.5">
                <span class="text-accent-green mt-0.5 text-xs">&#10003;</span>
                Import from LighterPack or CSV in seconds
              </li>
              <li class="flex items-start gap-2.5">
                <span class="text-accent-green mt-0.5 text-xs">&#10003;</span>
                Auto-fill weights from the product database
              </li>
              <li class="flex items-start gap-2.5">
                <span class="text-accent-green mt-0.5 text-xs">&#10003;</span>
                Create custom categories for organization
              </li>
              <li class="flex items-start gap-2.5">
                <span class="text-accent-green mt-0.5 text-xs">&#10003;</span>
                Track the total value of your kit
              </li>
            </ul>
          </div>
          <div class="md:w-7/12">
            <div class="rounded-xl border border-border overflow-hidden">
              <Image
                src={inventoryImg}
                alt="Packstack gear inventory showing categorized backpacking equipment with weights and product details"
                class="w-full block"
              />
            </div>
          </div>
        </div>
      </section>

      <!-- Feature: Pack List Builder -->
      <section class="py-16 md:py-24 px-4 bg-surface/30">
        <div class="max-w-6xl mx-auto flex flex-col md:flex-row-reverse items-center gap-8 md:gap-12">
          <div class="md:w-5/12">
            <h2 class="text-xs uppercase tracking-widest mb-3 font-semibold">Pack List Builder</h2>
            <h3 class="text-2xl md:text-3xl leading-snug mb-4">Build the perfect pack</h3>
            <p class="mb-5">
              Ditch the spreadsheets. Drag items from your inventory, organize
              by category, and fine-tune quantities — all in a clean,
              purpose-built interface. Create multiple packs per trip for base
              camp and day hike setups.
            </p>
            <ul class="space-y-2.5 text-softwhite text-sm">
              <li class="flex items-start gap-2.5">
                <span class="text-accent-green mt-0.5 text-xs">&#10003;</span>
                Drag-and-drop reordering
              </li>
              <li class="flex items-start gap-2.5">
                <span class="text-accent-green mt-0.5 text-xs">&#10003;</span>
                Multiple packs per trip
              </li>
              <li class="flex items-start gap-2.5">
                <span class="text-accent-green mt-0.5 text-xs">&#10003;</span>
                Built-in checklist mode
              </li>
              <li class="flex items-start gap-2.5">
                <span class="text-accent-green mt-0.5 text-xs">&#10003;</span>
                Mark items as worn or consumable
              </li>
            </ul>
          </div>
          <div class="md:w-7/12">
            <!-- CSS-only pack list mock -->
            <div class="rounded-xl border border-border bg-background overflow-hidden select-none" aria-hidden="true">
              <!-- Tab bar -->
              <div class="flex items-center bg-surface border-b border-border">
                <div class="py-2.5 px-5 text-sm font-semibold text-white border-b-2 border-primary">Base Pack</div>
                <div class="py-2.5 px-5 text-sm text-label">Summit Pack</div>
              </div>
              <!-- Weight summary -->
              <div class="flex flex-wrap items-center gap-x-6 gap-y-1 px-5 py-3 border-b border-border text-xs">
                <span><span class="text-label">Base</span><span class="text-white font-semibold ml-1.5">8.4 lb</span></span>
                <span><span class="text-label">Worn</span><span class="text-white font-semibold ml-1.5">2.1 lb</span></span>
                <span><span class="text-label">Consumable</span><span class="text-white font-semibold ml-1.5">3.2 lb</span></span>
                <span><span class="text-label">Total</span><span class="text-primary font-bold ml-1.5">13.7 lb</span></span>
              </div>
              <!-- Shelter category -->
              <div class="border-b border-border">
                <div class="bg-surface/60 px-5 py-2 text-xs font-semibold text-white uppercase tracking-wider">Shelter</div>
                <div class="flex items-center justify-between px-5 py-2 text-sm border-b border-border/40">
                  <div class="flex items-center gap-3 min-w-0">
                    <span class="w-4 h-4 shrink-0 rounded border-2 border-primary bg-primary/20 flex items-center justify-center text-[10px] text-primary leading-none">&#10003;</span>
                    <span class="text-white truncate">Tent</span>
                    <span class="text-label text-xs hidden sm:inline truncate">Big Agnes &middot; Copper Spur HV UL2</span>
                  </div>
                  <span class="text-softwhite text-sm tabular-nums shrink-0 ml-4">42 oz</span>
                </div>
                <div class="flex items-center justify-between px-5 py-2 text-sm border-b border-border/40">
                  <div class="flex items-center gap-3 min-w-0">
                    <span class="w-4 h-4 shrink-0 rounded border border-border/60"></span>
                    <span class="text-white truncate">Footprint</span>
                    <span class="text-label text-xs hidden sm:inline truncate">Tyvek Ground Sheet</span>
                  </div>
                  <span class="text-softwhite text-sm tabular-nums shrink-0 ml-4">5 oz</span>
                </div>
                <div class="flex items-center justify-between px-5 py-2 text-sm">
                  <div class="flex items-center gap-3 min-w-0">
                    <span class="w-4 h-4 shrink-0 rounded border border-border/60"></span>
                    <span class="text-white truncate">Stakes</span>
                    <span class="text-label text-xs hidden sm:inline truncate">MSR Groundhog Mini &times;6</span>
                  </div>
                  <span class="text-softwhite text-sm tabular-nums shrink-0 ml-4">3 oz</span>
                </div>
              </div>
              <!-- Sleep System category -->
              <div class="border-b border-border">
                <div class="bg-surface/60 px-5 py-2 text-xs font-semibold text-white uppercase tracking-wider">Sleep System</div>
                <div class="flex items-center justify-between px-5 py-2 text-sm border-b border-border/40">
                  <div class="flex items-center gap-3 min-w-0">
                    <span class="w-4 h-4 shrink-0 rounded border-2 border-primary bg-primary/20 flex items-center justify-center text-[10px] text-primary leading-none">&#10003;</span>
                    <span class="text-white truncate">Quilt</span>
                    <span class="text-label text-xs hidden sm:inline truncate">Enlightened Equipment &middot; Enigma 20&deg;</span>
                  </div>
                  <span class="text-softwhite text-sm tabular-nums shrink-0 ml-4">24 oz</span>
                </div>
                <div class="flex items-center justify-between px-5 py-2 text-sm">
                  <div class="flex items-center gap-3 min-w-0">
                    <span class="w-4 h-4 shrink-0 rounded border border-border/60"></span>
                    <span class="text-white truncate">Sleeping Pad</span>
                    <span class="text-label text-xs hidden sm:inline truncate">Therm-a-Rest &middot; NeoAir XLite</span>
                  </div>
                  <span class="text-softwhite text-sm tabular-nums shrink-0 ml-4">12 oz</span>
                </div>
              </div>
              <!-- Cooking category -->
              <div>
                <div class="bg-surface/60 px-5 py-2 text-xs font-semibold text-white uppercase tracking-wider">Cooking</div>
                <div class="flex items-center justify-between px-5 py-2 text-sm border-b border-border/40">
                  <div class="flex items-center gap-3 min-w-0">
                    <span class="w-4 h-4 shrink-0 rounded border border-border/60"></span>
                    <span class="text-white truncate">Stove</span>
                    <span class="text-label text-xs hidden sm:inline truncate">BRS &middot; 3000T</span>
                  </div>
                  <span class="text-softwhite text-sm tabular-nums shrink-0 ml-4">0.9 oz</span>
                </div>
                <div class="flex items-center justify-between px-5 py-2 text-sm">
                  <div class="flex items-center gap-3 min-w-0">
                    <span class="w-4 h-4 shrink-0 rounded border border-border/60"></span>
                    <span class="text-white truncate">Pot</span>
                    <span class="text-label text-xs hidden sm:inline truncate">TOAKS &middot; 750ml Titanium</span>
                  </div>
                  <span class="text-softwhite text-sm tabular-nums shrink-0 ml-4">3.4 oz</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Feature: Weight Analysis -->
      <section class="py-16 md:py-24 px-4">
        <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center gap-8 md:gap-12">
          <div class="md:w-5/12">
            <h2 class="text-xs uppercase tracking-widest mb-3 font-semibold">Weight Analysis</h2>
            <h3 class="text-2xl md:text-3xl leading-snug mb-4">Know your base weight</h3>
            <p class="mb-5">
              Instantly see how your weight is distributed across categories.
              Packstack separates base weight, worn weight, and consumables so
              you always know exactly what your pack weighs on the trail.
            </p>
            <ul class="space-y-2.5 text-softwhite text-sm">
              <li class="flex items-start gap-2.5">
                <span class="text-accent-green mt-0.5 text-xs">&#10003;</span>
                Base / worn / consumable breakdown
              </li>
              <li class="flex items-start gap-2.5">
                <span class="text-accent-green mt-0.5 text-xs">&#10003;</span>
                Category-level weight visualization
              </li>
              <li class="flex items-start gap-2.5">
                <span class="text-accent-green mt-0.5 text-xs">&#10003;</span>
                Toggle between metric and imperial
              </li>
            </ul>
          </div>
          <div class="md:w-7/12">
            <div class="rounded-xl border border-border overflow-hidden">
              <Image
                src={weightImg}
                alt="Weight breakdown pie chart showing pack weight distribution by category with totals"
                class="w-full block"
              />
            </div>
          </div>
        </div>
      </section>

      <!-- Feature: Trip Planning -->
      <section class="py-16 md:py-24 px-4 bg-surface/30">
        <div class="max-w-6xl mx-auto flex flex-col md:flex-row-reverse items-center gap-8 md:gap-12">
          <div class="md:w-5/12">
            <h2 class="text-xs uppercase tracking-widest mb-3 font-semibold">Trip Planning</h2>
            <h3 class="text-2xl md:text-3xl leading-snug mb-4">Plan beyond the packing list</h3>
            <p class="mb-5">
              Capture everything about your trip &mdash; location, dates, distance,
              daily elevation gain, terrain type, pace, and expected temperatures.
              These details power the calorie calculator so your food plan matches
              the trail ahead.
            </p>
            <ul class="space-y-2.5 text-softwhite text-sm">
              <li class="flex items-start gap-2.5">
                <span class="text-accent-green mt-0.5 text-xs">&#10003;</span>
                Distance, elevation gain, and terrain
              </li>
              <li class="flex items-start gap-2.5">
                <span class="text-accent-green mt-0.5 text-xs">&#10003;</span>
                Pace and temperature range
              </li>
              <li class="flex items-start gap-2.5">
                <span class="text-accent-green mt-0.5 text-xs">&#10003;</span>
                Multi-day date ranges
              </li>
              <li class="flex items-start gap-2.5">
                <span class="text-accent-green mt-0.5 text-xs">&#10003;</span>
                Notes for trail conditions and tips
              </li>
            </ul>
          </div>
          <div class="md:w-7/12 flex justify-center md:justify-start">
            <!-- CSS-only trip details mock -->
            <div class="rounded-xl border border-border bg-background overflow-hidden w-full max-w-md select-none" aria-hidden="true">
              <div class="bg-surface px-5 py-4 border-b border-border">
                <div class="flex items-center gap-3">
                  <svg class="w-4 h-4 text-primary shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" /></svg>
                  <div class="min-w-0">
                    <div class="font-semibold text-white text-sm truncate">John Muir Trail &mdash; Southbound</div>
                    <div class="text-label text-xs mt-0.5">Jul 15 &ndash; Aug 2, 2026 &middot; 19 days</div>
                  </div>
                </div>
              </div>
              <div class="px-5 py-4">
                <div class="grid grid-cols-2 gap-x-6 gap-y-3">
                  <div>
                    <div class="text-[10px] text-label uppercase tracking-wide">Distance</div>
                    <div class="text-white font-semibold text-sm">211 mi</div>
                  </div>
                  <div>
                    <div class="text-[10px] text-label uppercase tracking-wide">Elev. Gain</div>
                    <div class="text-white font-semibold text-sm">2,400 ft/day</div>
                  </div>
                  <div>
                    <div class="text-[10px] text-label uppercase tracking-wide">Terrain</div>
                    <div class="text-white font-semibold text-sm">Rugged</div>
                  </div>
                  <div>
                    <div class="text-[10px] text-label uppercase tracking-wide">Pace</div>
                    <div class="text-white font-semibold text-sm">Moderate (3 mph)</div>
                  </div>
                  <div>
                    <div class="text-[10px] text-label uppercase tracking-wide">Temperature</div>
                    <div class="text-white font-semibold text-sm">32&ndash;75&deg;F</div>
                  </div>
                  <div>
                    <div class="text-[10px] text-label uppercase tracking-wide">Temp Category</div>
                    <div class="text-white font-semibold text-sm">Moderate</div>
                  </div>
                </div>
              </div>
              <div class="bg-surface/60 px-5 py-3 border-t border-border">
                <div class="text-xs text-label italic">High passes may hold snow through mid-July. Bring microspikes.</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Feature: Hiker Profiles -->
      <section class="py-16 md:py-24 px-4">
        <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center gap-8 md:gap-12">
          <div class="md:w-5/12">
            <h2 class="text-xs uppercase tracking-widest mb-3 font-semibold">Hiker Profiles</h2>
            <h3 class="text-2xl md:text-3xl leading-snug mb-4">Your stats, your estimate</h3>
            <p class="mb-5">
              Create hiker profiles with your weight, height, age, sex, and body
              type. Assign a profile to any pack &mdash; perfect for couples or
              groups. Your stats feed directly into the calorie calculator for
              personalized daily estimates.
            </p>
            <ul class="space-y-2.5 text-softwhite text-sm">
              <li class="flex items-start gap-2.5">
                <span class="text-accent-green mt-0.5 text-xs">&#10003;</span>
                Weight, height, age, sex, and body type
              </li>
              <li class="flex items-start gap-2.5">
                <span class="text-accent-green mt-0.5 text-xs">&#10003;</span>
                Assign profiles to individual packs
              </li>
              <li class="flex items-start gap-2.5">
                <span class="text-accent-green mt-0.5 text-xs">&#10003;</span>
                Powers personalized calorie estimates
              </li>
              <li class="flex items-start gap-2.5">
                <span class="text-accent-green mt-0.5 text-xs">&#10003;</span>
                Set a default profile
              </li>
            </ul>
          </div>
          <div class="md:w-7/12">
            <!-- CSS-only hiker profiles mock -->
            <div class="rounded-xl border border-border bg-background overflow-hidden select-none" aria-hidden="true">
              <div class="bg-surface px-5 py-3 border-b border-border flex items-center gap-2.5">
                <svg class="w-4 h-4 text-primary shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4-4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" /></svg>
                <span class="font-semibold text-white text-sm">Hiker Profiles</span>
              </div>
              <div class="divide-y divide-border/40">
                <div class="px-5 py-3">
                  <div class="flex items-center justify-between mb-1">
                    <span class="text-white font-semibold text-sm">Sarah</span>
                    <span class="text-[10px] text-primary font-semibold uppercase tracking-wide bg-primary/10 rounded-full px-2 py-0.5">Default</span>
                  </div>
                  <div class="text-label text-xs">135 lb &middot; 5&rsquo;6&rdquo; &middot; Age 32 &middot; Female &middot; Average</div>
                </div>
                <div class="px-5 py-3">
                  <div class="flex items-center justify-between mb-1">
                    <span class="text-white font-semibold text-sm">Mike</span>
                  </div>
                  <div class="text-label text-xs">185 lb &middot; 5&rsquo;11&rdquo; &middot; Age 34 &middot; Male &middot; High Muscle</div>
                </div>
              </div>
              <div class="bg-surface/60 px-5 py-3 border-t border-border flex justify-end">
                <div class="bg-primary text-white text-xs font-semibold rounded-md px-4 py-2">+ Add Profile</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Feature: Calorie Calculator -->
      <section class="py-16 md:py-24 px-4 bg-surface/30">
        <div class="max-w-6xl mx-auto flex flex-col md:flex-row-reverse items-center gap-8 md:gap-12">
          <div class="md:w-5/12">
            <h2 class="text-xs uppercase tracking-widest mb-3 font-semibold">Calorie Calculator</h2>
            <h3 class="text-2xl md:text-3xl leading-snug mb-4">Know how much fuel you need</h3>
            <p class="mb-5">
              Packstack estimates your daily calorie needs based on your body
              stats, pack weight, trail distance, elevation gain, terrain, pace,
              and temperature. See a full breakdown with macros, food weight,
              water needs, and trip totals.
            </p>
            <ul class="space-y-2.5 text-softwhite text-sm">
              <li class="flex items-start gap-2.5">
                <span class="text-accent-green mt-0.5 text-xs">&#10003;</span>
                Daily calorie estimate from trip + body stats
              </li>
              <li class="flex items-start gap-2.5">
                <span class="text-accent-green mt-0.5 text-xs">&#10003;</span>
                Macro breakdown (carbs, fat, protein)
              </li>
              <li class="flex items-start gap-2.5">
                <span class="text-accent-green mt-0.5 text-xs">&#10003;</span>
                Food weight and water estimates
              </li>
              <li class="flex items-start gap-2.5">
                <span class="text-accent-green mt-0.5 text-xs">&#10003;</span>
                Optional +10% safety margin
              </li>
            </ul>
          </div>
          <div class="md:w-7/12 flex justify-center md:justify-start">
            <!-- CSS-only calorie estimate mock -->
            <div class="rounded-xl border border-border bg-background overflow-hidden w-full max-w-md select-none" aria-hidden="true">
              <div class="bg-surface px-5 py-3 border-b border-border flex items-center gap-2">
                <svg class="w-4 h-4 text-accent-orange shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22c-4.97 0-9-2.69-9-6v-.5C3 9.5 8 3 12 2c4 1 9 7.5 9 13.5v.5c0 3.31-4.03 6-9 6z" /></svg>
                <span class="font-semibold text-white text-sm">Calorie Estimate</span>
              </div>
              <div class="px-5 py-2 border-b border-border bg-surface/50">
                <div class="text-xs text-label">Sarah &mdash; JMT Southbound</div>
              </div>
              <div class="px-5 py-3 space-y-1">
                <div class="flex justify-between py-0.5 border-b border-border pb-2 mb-1">
                  <span class="font-semibold text-accent-orange text-sm flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22c-4.97 0-9-2.69-9-6v-.5C3 9.5 8 3 12 2c4 1 9 7.5 9 13.5v.5c0 3.31-4.03 6-9 6z" /></svg>
                    Daily
                  </span>
                  <span class="font-semibold text-accent-orange text-sm tabular-nums">3,847 kcal</span>
                </div>
                <div class="flex justify-between py-0.5 text-sm">
                  <span class="text-label">Food / day</span>
                  <span class="text-white tabular-nums">1.85 lb</span>
                </div>
                <div class="grid grid-cols-3 gap-1.5 py-1.5">
                  <div class="bg-surface/60 rounded-md px-2 py-1.5 text-center">
                    <div class="text-[10px] text-label">Carbs</div>
                    <div class="text-white text-xs font-medium">481g</div>
                  </div>
                  <div class="bg-surface/60 rounded-md px-2 py-1.5 text-center">
                    <div class="text-[10px] text-label">Fat</div>
                    <div class="text-white text-xs font-medium">128g</div>
                  </div>

---
import { getCollection } from "astro:content"
import BaseLayout from "../../../layouts/BaseLayout.astro"
import PageHeader from "../../../components/PageHeader.astro"
import PageFooter from "../../../components/PageFooter.astro"

export const prerender = true

export async function getStaticPaths() {
  const reviews = await getCollection("reviews")

  const categoryMap = new Map<string, { displayName: string; reviews: typeof reviews }>()

  for (const review of reviews) {
    const slug = review.id.split("/")[0]
    const existing = categoryMap.get(slug)
    if (existing) {
      existing.reviews.push(review)
    } else {
      categoryMap.set(slug, {
        displayName: review.data.category,
        reviews: [review],
      })
    }
  }

  return Array.from(categoryMap.entries()).map(([slug, { displayName, reviews }]) => {
    const sorted = reviews.sort(
      (a, b) => new Date(b.data.published_at).getTime() - new Date(a.data.published_at).getTime()
    )
    return {
      params: { category: slug },
      props: { displayName, reviews: sorted },
    }
  })
}

const { category } = Astro.params
const { displayName, reviews } = Astro.props
---

<BaseLayout title={`${displayName} Reviews | Packstack`} description={`All ${displayName.toLowerCase()} reviews — weights, specs, and honest takes.`}>
  <div class="bg-background min-h-screen">
    <PageHeader />

    <main class="max-w-5xl mx-auto px-4 md:px-8 py-12">
      <div class="mb-8">
        <a href="/reviews" class="text-sm text-label hover:text-primary transition-colors no-underline">&larr; All Reviews</a>
      </div>

      <h1 class="text-3xl md:text-4xl font-bold mb-2">{displayName} Reviews</h1>
      <p class="text-lg mb-8">All {displayName.toLowerCase()} gear reviews.</p>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {reviews.map((review) => (
          <a href={`/reviews/${review.id}`} class="group block bg-surface rounded-lg border border-border hover:border-primary/50 transition-colors no-underline overflow-hidden">
            {review.data.image_url && (
              <div class="aspect-4/3 bg-surface-light overflow-hidden">
                <img src={review.data.image_url} alt={review.data.title} class="w-full h-full object-contain p-4" />
              </div>
            )}
            <div class="p-4">
              <h3 class="text-white font-semibold group-hover:text-primary transition-colors">{review.data.title}</h3>
              <p class="text-sm text-softwhite mt-1 line-clamp-2">{review.data.description}</p>
              <div class="flex items-center gap-3 mt-3 text-xs text-label">
                <span>{review.data.brand}</span>
                {review.data.weight_grams && <span>{review.data.weight_grams}g</span>}
                {review.data.rating && <span>Rating: {review.data.rating}/10</span>}
              </div>
            </div>
          </a>
        ))}
      </div>
    </main>

    <PageFooter />
  </div>
</BaseLayout>

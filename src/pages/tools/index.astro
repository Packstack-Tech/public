---
import BaseLayout from "../../layouts/BaseLayout.astro"
import PageHeader from "../../components/PageHeader.astro"
import PageFooter from "../../components/PageFooter.astro"

export const prerender = true

const tools = [
  {
    title: "Backpacking Calorie Calculator",
    description: "Estimate daily calorie needs on the trail using the Pandolf Load Carriage Equation. Factor in pack weight, terrain, pace, elevation, and more.",
    href: "/tools/backpacking-calorie-calculator",
  },
  {
    title: "Water Carry Estimator",
    description: "Calculate exactly how much water to carry between sources based on distance, elevation, temperature, and your sweat rate.",
    href: "/tools/water-carry-estimator",
  },
]
---

<BaseLayout title="Backpacking Tools | Packstack" description="Free backpacking calculators and planning tools — calorie estimators, gear weight analysis, and more.">
  <div class="bg-background min-h-screen">
    <PageHeader />

    <main class="max-w-5xl mx-auto px-4 md:px-8 py-12">
      <h1 class="text-3xl md:text-4xl font-bold mb-2">Backpacking Tools</h1>
      <p class="text-lg mb-10">Free calculators and planning tools for your next trip.</p>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {tools.map((tool) => (
          <a href={tool.href} class="group block bg-surface rounded-lg border border-border hover:border-primary/50 transition-colors no-underline overflow-hidden">
            <div class="p-5">
              <h3 class="text-white font-semibold group-hover:text-primary transition-colors">{tool.title}</h3>
              <p class="text-sm text-softwhite mt-2 leading-relaxed">{tool.description}</p>
              <span class="inline-block mt-4 text-xs text-primary font-semibold group-hover:translate-x-0.5 transition-transform">Try it &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </main>

    <PageFooter />
  </div>
</BaseLayout>
